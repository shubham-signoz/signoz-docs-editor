{
  "name": "signoz-docs-editor",
  "version": "0.2.8",
  "private": false,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "signoz-docs-editor": "bin/signoz-docs-editor.js"
  },
  "files": [
    "bin",
    "server.js",
    "vite.config.ts",
    "vite-plugin-*.ts",
    "signoz-component-registry.js",
    "index.html",
    "postcss.config.js",
    "tailwind.config.js",
    "tsconfig.json",
    "tsconfig.node.json",
    "src/App.tsx",
    "src/main.tsx",
    "src/index.css",
    "src/mdx-compiler.ts",
    "src/virtual-modules.d.ts",
    "src/vite-env.d.ts",
    "src/contexts/*.ts",
    "src/contexts/*.tsx",
    "src/components/*.ts",
    "src/components/*.tsx",
    "src/discovery/*.ts",
    "src/discovery/*.tsx",
    "src/discovery/*.js",
    "src/discovery/*.d.ts",
    "src/hooks/*.ts",
    "src/hooks/*.tsx",
    "src/shims/*.ts",
    "src/shims/*.tsx",
    "src/types/*.ts",
    "src/types/*.d.ts",
    "src/utils/*.ts",
    "src/utils/*.tsx",
    "src/utils/*.d.ts"
  ],
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "start": "node bin/signoz-docs-editor.js",
    "start:dev": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest --pool=threads --poolOptions.threads.maxThreads=1 --poolOptions.threads.minThreads=1",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-markdown": "^6.3.0",
    "@mdx-js/mdx": "^3.0.1",
    "@mdxeditor/editor": "^3.52.3",
    "@tailwindcss/typography": "^0.5.19",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "codemirror": "^6.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.563.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-medium-image-zoom": "^5.4.0",
    "react-split": "^2.0.14",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-code-titles": "^0.1.2",
    "remark-gfm": "^4.0.1",
    "sucrase": "^3.35.1",
    "tailwindcss": "^3.4.14",
    "ts-morph": "^23.0.0",
    "vite": "^5.4.10"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.2.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
